set(CMAKE_BUILD_TYPE "Debug"                CACHE STRING "build type" FORCE)
set(CGALPY_USE_SHARED_LIBS ON               CACHE BOOL "use shared libs" FORCE)
set(CGALPY_FIXED_LIBRARY_NAME OFF           CACHE BOOL "use name CGALPY" FORCE)
set(CGALPY_KERNEL_NAME "epec"               CACHE STRING "use EPEC kernel" FORCE)
set(CGALPY_ARRANGEMENT_ON_SURFACE_2_BINDINGS ON CACHE BOOL "2D AOS" FORCE)
set(CGALPY_AOS2_GEOMETRY_TRAITS_NAME "circleSegment" CACHE STRING "use circle-segments" FORCE)
set(CGALPY_AOS2_VERTEX_EXTENDED ON          CACHE BOOL "extend vertex type" FORCE)
