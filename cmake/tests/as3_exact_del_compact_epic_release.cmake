set(CMAKE_BUILD_TYPE "Release"                 CACHE STRING "build type" FORCE)
set(CGALPY_USE_SHARED_LIBS ON                  CACHE BOOL "" FORCE)
set(CGALPY_FIXED_LIBRARY_NAME:BOOL OFF         CACHE BOOL "" FORCE)
set(CGALPY_KERNEL_NAME "epic"                  CACHE STRING "use EPIC kernel" FORCE)
set(CGALPY_ALPHA_SHAPE_3_BINDINGS ON           CACHE BOOL "" FORCE)
set(CGALPY_AS3_EXACT_COMPARISON ON             CACHE BOOL "" FORCE)
set(CGALPY_TRIANGULATION_3_BINDINGS ON         CACHE BOOL "" FORCE)
set(CGALPY_TRI3_VERTEX_BASE_NAME "alphaShape"  CACHE STRING "" FORCE)
set(CGALPY_TRI3_CELL_BASE_NAME "alphaShape"    CACHE STRING "" FORCE)
set(CGALPY_TRI3_NAME "delaunay"                CACHE STRING "" FORCE)
set(CGALPY_TRI3_LOCATION_POLICY_NAME "compact" CACHE STRING "" FORCE)
