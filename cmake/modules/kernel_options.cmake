if(NOT KERNEL_OPTIONS_FILE_INCLUDED)
set(KERNEL_OPTIONS_FILE_INCLUDED)

# Options
set(CGALPY_KERNEL_TYPE_EPEC 0)
set(CGALPY_KERNEL_TYPE_EPIC 1)

# Names
set(CGALPY_KERNEL_TYPE_SHORT_NAMES "epec" "epic")
set(CGALPY_KERNEL_TYPE_NAMES "epec" "epic")

# Default
SET(CGALPY_KERNEL_TYPE_NAME "epec" CACHE STRING "The kernel to use")
set(CGALPY_KERNEL_TYPE ${CGALPY_KERNEL_TYPE_EPEC} CACHE INTERNAL "")
set_property(CACHE CGALPY_KERNEL_TYPE_NAME PROPERTY STRINGS epec epic)

function(select_kernel)
  if ("${CGALPY_KERNEL_TYPE_NAME}" STREQUAL "epec")
    set(CGALPY_KERNEL_TYPE ${CGALPY_KERNEL_TYPE_EPEC} CACHE INTERNAL "")
  elseif ("${CGALPY_KERNEL_TYPE_NAME}" STREQUAL "epic")
    set(CGALPY_KERNEL_TYPE ${CGALPY_KERNEL_TYPE_EPIC} CACHE INTERNAL "")
  endif()
  add_definitions(-DCGALPY_KERNEL_TYPE=${CGALPY_KERNEL_TYPE})
endfunction()

endif()
