{
  "CGAL::Polygon_repair::Even_odd_rule": {
    "kind": "struct",
    "name": "CGAL::Polygon_repair::Even_odd_rule",
    "brief": "Tag class to select the even odd rule when calling CGAL::Polygon_repair::repair() .",
    "detailed": "The even-odd rule results in areas that are alternately assigned as polygon interiors and exterior/holes each time that an input edge is passed. It does not distinguish between edges that are part of outer boundaries from those of inner boundaries.",
    "members": []
  },
  "CGAL::Polygon_repair::Intersection_rule": {
    "kind": "struct",
    "name": "CGAL::Polygon_repair::Intersection_rule",
    "brief": "Tag class to select the intersection rule when calling CGAL::Polygon_repair::repair() .",
    "detailed": "The intersection rule are useful when given two or more similar valid polygons with holes. The intersection rule results in areas that are contained in all input polygons with holes.",
    "members": []
  },
  "CGAL::Polygon_repair::Non_zero_rule": {
    "kind": "struct",
    "name": "CGAL::Polygon_repair::Non_zero_rule",
    "brief": "Tag class to select the non zero rule when calling CGAL::Polygon_repair::repair() .",
    "detailed": "The non-zero rule results in areas with a non-zero winding number.",
    "members": []
  },
  "CGAL::Polygon_repair::Union_rule": {
    "kind": "struct",
    "name": "CGAL::Polygon_repair::Union_rule",
    "brief": "Tag class to select the union rule when calling CGAL::Polygon_repair::repair() .",
    "detailed": "The union rules are useful when given two or more similar valid polygons with holes. The union rule results in areas that are contained in at least one of the input polygons with holes.",
    "members": []
  },
