    "PkgPolygonalSurfaceReconstructionRef": {
      "kind": "group",
      "name": "PkgPolygonalSurfaceReconstructionRef",
      "brief": "",
      "detailed": "Liangliang Nan This package provides a method for piecewise planar object reconstruction from point clouds. The method takes as input an unordered point set (and optionally planar segments) of a piecewise planar object and outputs a lightweight and watertight surface mesh interpolating the input point set. The method can handle arbitrary piecewise planar objects and is capable of recovering sharp features and is robust to noise and outliers. Introduced in: CGAL 4.14 Depends on: PkgAlphaShapes2 and PkgSolverInterface BibTeX: cgal:x-x-26a License: GPL Classified Reference Pages Classes CGAL::Polygonal_surface_reconstruction <Gt>",
      "members": [],
      "xml_file": "group___pkg_polygonal_surface_reconstruction_ref.xml"
    }
