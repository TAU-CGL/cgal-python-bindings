      {
        "kind": "function",
        "name": "operator()",
        "qualified_name": "CGAL::Polyline_simplification_2::Hybrid_squared_distance_cost::operator()",
        "brief": "Compute the hybrid squared distance cost.",
        "detailed": "Given a vertex in constraint iterator vicq computes vicp=std::prev(vicq) and vicr=std::next(vicq) , returns the maximal square distance between each point along the original subpolyline, between vicp and vicr , and the straight line segment from *vicp->point() to *vicr->point() divided by the smallest of the square of the ratio given to the constructor of the cost function, and the shortest squared distance between that segment and each of the vertices adjacent to vicq . CDT must be CGAL::Constrained_Delaunay_triangulation_2 with a vertex type that is model of PolylineSimplificationVertexBase_2 .",
        "return_type": "std::optional< typename CDT::Geom_traits::FT >",
        "argsstring": "(const Constrained_triangulation_plus_2< CDT > &pct, typename Constrained_triangulation_plus_2< CDT >::Vertices_in_constraint_iterator vicq) const",
        "params": [
          {
            "type": "const Constrained_triangulation_plus_2< CDT > &",
